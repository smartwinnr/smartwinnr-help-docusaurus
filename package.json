  "main": "index.js",
  "scripts": {
    "dev": "docusaurus start --port 3001",
    "start": "npm run build && node server.js",
    "start:docs": "docusaurus start --port 3000",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "node server.js",
    "serve:docs": "docusaurus serve --port 3000",
    "start:railway": "node scripts/internal-indexer.js && node server.js",
    "serve-and-index": "npm run serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "chatbot:start": "API_PORT=3002 tsx services/chatbot/server.ts",
    "chatbot:dev": "API_PORT=3002 tsx watch services/chatbot/server.ts",
    "start:production": "npm run chatbot:start",
    "dev:old": "concurrently \"npm run start:docs\" \"npm run chatbot:dev\"",
    "dev:full": "concurrently --names \"DOCS,CHAT\" --prefix-colors \"blue,green\" \"npm run start:docs\" \"npm run chatbot:dev\"",
    "index-docs": "tsx services/chatbot/indexDocs.ts",
    "index-internal": "node scripts/internal-indexer.js",
    "lint:docs": "markdownlint-cli2",
    "lint:docs:fix": "markdownlint-cli2 --fix",
    "prepare": "husky"
  },
