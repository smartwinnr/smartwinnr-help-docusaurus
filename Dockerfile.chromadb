# Dockerfile.chromadb
FROM chromadb/chroma:0.6.3

# Safe defaults for Railway
ENV CHROMA_SERVER_HOST="::" \
    CHROMA_SERVER_HTTP_PORT=8000 \
    IS_PERSISTENT=TRUE \
    PERSIST_DIRECTORY=/data \
    ANONYMIZED_TELEMETRY=FALSE \
    CHROMA_SERVER_CORS_ALLOW_ORIGINS=[]
# No CMD here; the image's entrypoint starts the server
