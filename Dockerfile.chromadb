# Use the official image (or your own) and RUN chroma explicitly
FROM ghcr.io/chroma-core/chroma:latest

# Persist to a mounted path
ENV PERSIST_DIRECTORY=/chroma/data
ENV ANONYMIZED_TELEMETRY=False

# **Critical**: bind to ALL interfaces and explicit port
ENV CHROMA_SERVER_HOST=0.0.0.0
ENV CHROMA_SERVER_HTTP_PORT=8000

EXPOSE 8000

# Start ChromaDB server
CMD ["uvicorn", "chromadb.app:app", "--host", "0.0.0.0", "--port", "8000"]