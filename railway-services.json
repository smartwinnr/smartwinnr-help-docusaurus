{
  "name": "smartwinnr-help",
  "description": "SmartWinnr Help Documentation with AI Chatbot",
  "services": [
    {
      "name": "chatbot-api",
      "dockerfile": "Dockerfile.chatbot",
      "port": 3002,
      "environment": {
        "NODE_ENV": "production",
        "API_PORT": "3002",
        "CHROMA_HOST": "chromadb",
        "CHROMA_PORT": "8000",
        "CORS_ORIGIN": "https://help-smartwinnr.up.railway.app",
        "COLLECTION_NAME": "smartwinnr_docs",
        "EMBEDDING_MODEL": "text-embedding-3-small",
        "CHAT_MODEL": "gpt-4o-mini",
        "LOG_LEVEL": "info"
      },
      "healthcheck": {
        "path": "/health",
        "timeout": 30
      },
      "scaling": {
        "minReplicas": 1,
        "maxReplicas": 3
      }
    },
    {
      "name": "chromadb",
      "dockerfile": "Dockerfile.chromadb",
      "port": 8000,
      "environment": {
        "CHROMA_HOST": "0.0.0.0",
        "CHROMA_PORT": "8000",
        "PERSIST_DIRECTORY": "/chroma/data",
        "ANONYMIZED_TELEMETRY": "False"
      },
      "volumes": [
        {
          "name": "chromadb-data",
          "mountPath": "/chroma/data"
        }
      ],
      "healthcheck": {
        "path": "/api/v1/heartbeat",
        "timeout": 30
      },
      "scaling": {
        "minReplicas": 1,
        "maxReplicas": 1
      }
    }
  ],
  "networking": {
    "internal": {
      "chromadb": "chromadb.railway.internal:8000"
    }
  }
}