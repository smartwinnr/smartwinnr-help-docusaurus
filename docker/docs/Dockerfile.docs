# docker/docs/Dockerfile.docs
# 1) Build static site
FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# 2) Serve with Nginx and proxy /api -> chatbot-api
FROM nginx:1.27-alpine
# Nginx listens on 80 by default
EXPOSE 80

# Add our nginx config
COPY docker/docs/nginx.conf /etc/nginx/conf.d/default.conf

# Static files
COPY --from=build /app/build /usr/share/nginx/html

CMD ["nginx", "-g", "daemon off;"]