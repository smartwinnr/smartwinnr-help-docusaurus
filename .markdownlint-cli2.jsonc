{
  "globs": [
    "docs/**/*.md"
  ],
  "ignores": [
    "node_modules/**",
    "**/node_modules/**", 
    "docs-backup/**",
    "chroma/**",
    "**/README.md"
  ],
  "config": {
    "MD036": false,
    "MD025": false,
    "MD033": false,
    "MD013": false,
    "MD041": false,
    "MD045": false,
    "MD024": false,
    "MD059": false,
    "MD040": false,
    "MD039": false,
    "MD029": false,
    "MD001": false,
    "MD051": false
  },
  "customRules": ["./custom-markdownlint-rules.js"]
}