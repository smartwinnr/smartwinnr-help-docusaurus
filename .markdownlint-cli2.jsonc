{
  "config": {
    "default": false
  },
  "customRules": [],
  "globs": [
    "docs/**/*.md"
  ],
  "ignores": [
    "node_modules/**",
    "**/node_modules/**", 
    "docs-backup/**",
    "chroma/**",
    "**/README.md"
  ],
  "fix": false,
  "outputFormatters": [
    ["markdownlint-cli2-formatter-default", {
      "appendLink": true
    }]
  ]
}