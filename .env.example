# ===================================
# ENVIRONMENT CONFIGURATION
# ===================================

# Environment (development, production)
NODE_ENV=development
LOG_LEVEL=info

# ===================================
# LOCAL DEVELOPMENT (NODE_ENV=development)
# ===================================

# OpenAI Configuration - LOCAL ONLY
# In development, set your API key here
OPENAI_API_KEY=your_openai_api_key_here

# ===================================
# PRODUCTION CONFIGURATION (NODE_ENV=production) 
# ===================================

# AWS Secrets Manager Configuration - PRODUCTION ONLY
# When NODE_ENV=production, OpenAI API key will be fetched from AWS Secrets Manager
AWS_REGION=us-east-1
AWS_SECRET_NAME=smartwinnr/openai-api-key
AWS_SECRET_KEY=OPENAI_API_KEY

# AWS IAM Role/User needs these permissions:
# - secretsmanager:GetSecretValue
# - secretsmanager:DescribeSecret

# ===================================
# CHROMADB CONFIGURATION
# ===================================

CHROMA_HOST=localhost
CHROMA_PORT=8000

# ===================================
# SERVER CONFIGURATION
# ===================================

API_PORT=3002
CORS_ORIGIN=http://localhost:3001

# Production CORS origin should be:
# CORS_ORIGIN=https://help.smartwinnr.com

# ===================================
# VECTOR DATABASE SETTINGS
# ===================================

COLLECTION_NAME=smartwinnr_docs
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Available models:
# Chat Models: gpt-4, gpt-4-turbo, gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# Embedding Models: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002

# ===================================
# COST OPTIMIZATION
# ===================================

# For lower costs, use:
# CHAT_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# For better quality (higher cost):
# CHAT_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-large