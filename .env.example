# ===================================
# ENVIRONMENT CONFIGURATION
# ===================================

# Environment (development, production)
NODE_ENV=development
LOG_LEVEL=info

# ===================================
# LOCAL DEVELOPMENT (NODE_ENV=development)
# ===================================

# OpenAI Configuration - LOCAL ONLY
# In development, set your API key here
OPENAI_API_KEY=your_openai_api_key_here

# Authoring skill - superadmin /admin/authoring page
# Model used by POST /api/admin/authoring/generate (defaults to gpt-4o)
# AUTHORING_MODEL=gpt-4o
# Per-superadmin LLM rate limit (default 10 generates / 60-min window)
# AUTHORING_RATE_LIMIT=10

# Publish-to-deploy pipeline (plan §20.3 - server uses the GitHub Git
# Data API to push changed file(s) to the watched branch, Railway auto-
# redeploys from the new git state). Set ALL THREE on Railway to enable;
# leave any unset locally to keep deploys as a no-op for dev.
#
# AUTHORING_GIT_PUSH=true                              # turn deploy step on (falsy → no-op)
# GIT_PUSH_TOKEN=<GitHub fine-grained PAT>             # see below for scope
# GITHUB_REPO=smartwinnr/smartwinnr-help-docusaurus    # owner/repo
# GIT_PUBLISH_BRANCH=main                              # branch Railway watches
# GITHUB_API=https://api.github.com                    # override only for GHES
#
# GIT_PUSH_TOKEN must be a FINE-GRAINED personal access token scoped to
# ONLY this one repo:
#   Resource owner: smartwinnr (the org)
#   Repository access: Only select repositories → smartwinnr-help-docusaurus
#   Permissions → Repository permissions:
#     Contents: Read and write     (required to push commits)
#     Metadata: Read-only          (auto-required by GitHub)
# Any other repo under the same account is untouchable by this token.
#
# Debounce + min-interval guards (per-server; default is 30 min after the
# last publish in a burst, capped at no more than 1 deploy per 60 min)
# AUTHORING_DEPLOY_DEBOUNCE_MS=1800000     # 30 min
# AUTHORING_DEPLOY_MIN_INTERVAL_MS=3600000 # 60 min

# ===================================
# PRODUCTION CONFIGURATION (NODE_ENV=production) 
# ===================================

# AWS Secrets Manager Configuration - PRODUCTION ONLY
# When NODE_ENV=production, OpenAI API key will be fetched from AWS Secrets Manager
AWS_REGION=us-east-1
AWS_SECRET_NAME=smartwinnr/openai-api-key
AWS_SECRET_KEY=OPENAI_API_KEY

# AWS IAM Role/User needs these permissions:
# - secretsmanager:GetSecretValue
# - secretsmanager:DescribeSecret

# ===================================
# CHROMADB CONFIGURATION
# ===================================

CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false

# ===================================
# SERVER CONFIGURATION
# ===================================

# Port Configuration:
# - Documentation Server (Docusaurus): 3000
# - Chatbot API Server: 3002
PORT=3000
API_PORT=3002
CORS_ORIGIN=http://localhost:3000

# Production CORS origin should be:
# CORS_ORIGIN=https://help.smartwinnr.com

# ===================================
# VECTOR DATABASE SETTINGS
# ===================================

COLLECTION_NAME=smartwinnr_docs
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Available models:
# Chat Models: gpt-4, gpt-4-turbo, gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# Embedding Models: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002

# ===================================
# COST OPTIMIZATION
# ===================================

# For lower costs, use:
# CHAT_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# For better quality (higher cost):
# CHAT_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-large

# ===================================
# ANTHROPIC API (optional - for Freshdesk AI clustering)
# ===================================

# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===================================
# AUTHENTICATION
# ===================================

HELP_JWT_SECRET=          # shared with smartwinnr_prd; generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
HELP_SITE_URL=https://help.smartwinnr.com
LAMBDA_MAGIC_LINK_URL=    # Lambda Function URL for magic link flow

# ===================================
# CHAT LOGGING
# ===================================

CHAT_LOGGING_ENABLED=true
CHAT_LOG_DB_PATH=/app/data/chat-logs.db
CHAT_LOG_RETENTION_DAYS=90
CHAT_LOGGER_CIRCUIT_RESET_MS=60000

# Backup (optional - set bucket to enable S3/R2 upload)
CHAT_LOG_BACKUP_INTERVAL_HOURS=24
# BACKUP_S3_BUCKET=

# ===================================
# INTERNAL SERVICE AUTH
# ===================================

INTERNAL_API_KEY=          # shared key for service-to-service calls (e.g. indexer → embed API); generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ===================================
# INDEXER CONFIGURATION
# ===================================

# Set to true to delete and rebuild the entire ChromaDB collection
FORCE_FULL_REINDEX=false
RUN_INDEXER=false