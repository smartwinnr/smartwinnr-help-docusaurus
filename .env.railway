# Railway Environment Variables Configuration
# Copy these variables to your Railway service environment settings

# ===========================================
# CHROMADB SERVICE ENVIRONMENT VARIABLES
# ===========================================
# Set these in your chromadb Railway service:
# No environment variables needed - ChromaDB runs with default settings

# ===========================================
# CHATBOT-API SERVICE ENVIRONMENT VARIABLES
# ===========================================
# Set these in your chatbot-api Railway service:

NODE_ENV=production
LOG_LEVEL=info
API_PORT=3002

# OpenAI Configuration (replace with your actual API key)
OPENAI_API_KEY=your_openai_api_key_here

# ChromaDB Connection (use Railway internal network)
# Replace 'chromadb' with your actual ChromaDB service name in Railway
CHROMA_HOST=chromadb.railway.internal
CHROMA_PORT=8000

# CORS Configuration (replace with your actual docusaurus service URL)
# Use your Railway-generated domain for the docusaurus service
CORS_ORIGIN=https://docusaurus-production-XXXX.up.railway.app

# Vector Database Settings
COLLECTION_NAME=smartwinnr_docs
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# ===========================================
# DOCUSAURUS SERVICE ENVIRONMENT VARIABLES
# ===========================================
# Set these in your docusaurus Railway service:

NODE_ENV=production

# API Configuration (replace with your actual chatbot-api service URL)
# Use your Railway-generated domain for the chatbot-api service
REACT_APP_API_URL=https://chatbot-api-production-XXXX.up.railway.app