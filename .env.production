# Production Environment Configuration for Railway
NODE_ENV=production
LOG_LEVEL=info

# Railway Service Configuration
PORT=3002
API_PORT=3002

# ChromaDB Configuration (Railway service)
CHROMA_HOST=chromadb.railway.internal
CHROMA_PORT=8000

# Production CORS Configuration
CORS_ORIGIN=https://help-smartwinnr.up.railway.app

# Vector Database Settings
COLLECTION_NAME=smartwinnr_docs
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# AWS Secrets Manager (for production)
AWS_REGION=us-east-1
AWS_SECRET_NAME=smartwinnr/openai-api-key
AWS_SECRET_KEY=OPENAI_API_KEY

# OpenAI Configuration (will be fetched from AWS Secrets Manager)
# OPENAI_API_KEY will be retrieved from AWS Secrets Manager in production